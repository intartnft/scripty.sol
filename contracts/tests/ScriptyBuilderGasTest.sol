    ) external {
        IScriptyBuilderV2(scriptyBuilderAddress).getHTMLURLSafe(
            htmlRequest
        );
    }

    // solc-ignore-next-line func-mutability
    function getHTMLURLSafe_Many(
        HTMLRequest memory htmlRequest
    ) external {
        IScriptyBuilderV2(scriptyBuilderAddress).getHTMLURLSafe(
            htmlRequest
        );
    }
}
